{
    "swagger": "2.0",
    "info": {
        "description": "API documentation for the workmate task manager.",
        "title": "Task Manager API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "http://www.swagger.io/support",
